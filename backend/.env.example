# Zerodha (Kite Connect)
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Groww -- TOTP flow (recommended, no daily approval)
GROWW_TOTP_TOKEN=your_groww_totp_token_here
GROWW_TOTP_SECRET=your_groww_totp_secret_here

# Groww -- API Key+Secret flow (fallback, needs daily approval on Groww dashboard)
GROWW_API_KEY=
GROWW_API_SECRET=

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# App authentication (leave ADMIN_PASSWORD empty to disable auth gate)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password_here

# Email alerts (optional)
SMTP_EMAIL=your_gmail@gmail.com
SMTP_APP_PASSWORD=your_gmail_app_password
